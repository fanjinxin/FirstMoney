.scl90-pie-wrap {
  border-radius: 32rpx;
  border: 2rpx solid rgba(var(--xia-deep-rgb), 0.12);
  background: rgba(255,255,255,0.9);
  padding: 32rpx;
  box-shadow: 0 8rpx 16rpx rgba(var(--xia-deep-rgb), 0.06);
}

.scl90-pie-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.scl90-pie-title { font-size: 28rpx; font-weight: 600; color: var(--xia-deep); }
.scl90-pie-tag {
  border-radius: 999rpx; background: rgba(var(--xia-deep-rgb), 0.06);
  padding: 8rpx 20rpx; font-size: 22rpx; font-weight: 600; color: var(--xia-deep); border: 2rpx solid rgba(var(--xia-deep-rgb), 0.15);
}

.scl90-pie-legend {
  display: flex; flex-wrap: wrap; gap: 24rpx;
  margin-top: 24rpx; font-size: 22rpx; color: var(--xia-deep);
}

.scl90-legend-item { display: flex; align-items: center; gap: 12rpx; }
.scl90-legend-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
