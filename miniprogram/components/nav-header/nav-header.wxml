<view class="nav-header {{sticky ? 'nav-header-sticky' : ''}}">
  <view class="nav-inner">
    <scroll-view class="nav-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="nav-list">
        <view 
          wx:for="{{navItems}}" 
          wx:key="path"
          id="nav-{{item.path === '/' ? 'home' : item.testId}}"
          class="nav-item {{currentPath === item.path ? 'active' : ''}} {{item.path === '/' ? 'home' : ''}}"
          data-item="{{item}}"
          bindtap="onNavTap"
        >{{item.name}}</view>
      </view>
    </scroll-view>
  </view>
</view>
