.page-wrap.animal-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 120rpx;
}

.animal-main {
  padding-top: 24rpx;
}

.animal-header-block {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.section-header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--xia-deep);
}

.section-header-desc {
  font-size: 28rpx;
  color: var(--xia-deep);
  margin-top: 8rpx;
}

.restart-btn {
  font-size: 26rpx;
  color: var(--xia-teal);
  text-decoration: underline;
  flex-shrink: 0;
}

.animal-desc {
  font-size: 28rpx;
  color: var(--xia-deep);
  line-height: 1.6;
  margin-bottom: 32rpx;
}

/* grid: 左列 2fr + 右列 1fr - 与 Web AnimalTest 一致 */
.animal-grid {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.animal-left {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.animal-right {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.animal-progress-wrap {
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(var(--xia-deep-rgb), 0.12);
  overflow: hidden;
  margin-bottom: 32rpx;
}

.animal-progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: var(--xia-deep);
  transition: width 0.3s ease;
}

.animal-question-card {
  border-radius: 32rpx;
  border: 2rpx solid rgba(var(--xia-deep-rgb), 0.12);
  background: #fff;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(var(--xia-deep-rgb), 0.06);
}

.animal-q-meta {
  font-size: 24rpx;
  color: rgba(var(--xia-deep-rgb), 0.6);
  margin-bottom: 16rpx;
}

.animal-q-text {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--xia-deep);
  line-height: 1.5;
  margin-bottom: 32rpx;
}

/* 选项：垂直列表，带文案的按钮 */
.animal-options {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.animal-opt {
  padding: 32rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(var(--xia-deep-rgb), 0.15);
  background: #fff;
  font-size: 28rpx;
  color: var(--xia-deep);
  transition: all 0.2s;
}

.animal-opt-selected {
  border-color: var(--xia-deep);
  background: var(--xia-deep);
  color: #fff !important;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(var(--xia-deep-rgb), 0.25);
}

.animal-nav-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.animal-btn-prev, .animal-btn-next {
  padding: 24rpx 40rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  margin: 0;
  line-height: 1.4;
}
.animal-btn-prev::after, .animal-btn-next::after { border: none; }

.animal-btn-prev {
  border: 2rpx solid rgba(var(--xia-deep-rgb), 0.2);
  background: transparent;
  color: var(--xia-deep);
}
.animal-btn-prev[disabled] { opacity: 0.5; }

.animal-btn-next {
  background: var(--xia-deep);
  color: #fff;
  border: 2rpx solid var(--xia-deep);
}
.animal-btn-next[disabled] { opacity: 0.5; }

.animal-progress-text {
  font-size: 26rpx;
  color: rgba(var(--xia-deep-rgb), 0.7);
}

.animal-btn-submit {
  width: 100%;
  padding: 32rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  background: var(--xia-deep);
  color: #fff;
  border: none;
}

.animal-btn-disabled {
  background: rgba(var(--xia-deep-rgb), 0.3);
  color: rgba(255,255,255,0.8);
}

.animal-tips {
  margin-top: 48rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(var(--xia-deep-rgb), 0.1);
  background: rgba(var(--xia-deep-rgb), 0.03);
}

.animal-tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--xia-deep);
  margin-bottom: 16rpx;
}

.animal-tips-item {
  font-size: 26rpx;
  color: var(--xia-deep);
  line-height: 1.6;
  margin-bottom: 8rpx;
}

/* 题目总览 - 与 scl90-overview-card / Web QuestionOverview 一致 */
.animal-overview-card {
  border-radius: 32rpx;
  border: 2rpx solid rgba(var(--xia-deep-rgb), 0.12);
  background: #fff;
  padding: 32rpx 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.animal-overview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.animal-overview-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--xia-deep);
}

.animal-overview-count {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--xia-deep);
}

.animal-overview-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
  font-size: 22rpx;
  color: var(--xia-deep);
}

.animal-legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.animal-legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.animal-dot-answered {
  background: var(--xia-sky);
}

.animal-dot-unanswered {
  background: rgba(var(--xia-deep-rgb), 0.2);
}

.animal-dot-current {
  background: var(--xia-deep);
}

.animal-overview-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx;
}

.animal-overview-btn {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  border: 2rpx solid;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.animal-overview-current {
  border-color: var(--xia-deep);
  background: var(--xia-deep);
  color: #fff;
}

.animal-overview-answered {
  border-color: rgba(var(--xia-sky-rgb), 0.5);
  background: rgba(var(--xia-sky-rgb), 0.2);
  color: var(--xia-sky);
}

.animal-overview-unanswered {
  border-color: rgba(var(--xia-deep-rgb), 0.15);
  background: #fff;
  color: rgba(var(--xia-deep-rgb), 0.5);
}
