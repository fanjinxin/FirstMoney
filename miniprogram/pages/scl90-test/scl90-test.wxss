/**
 * SCL-90 选择页样式 - 逐行对应 Web 版 Tailwind 主题色
 * 使用 --xia-* 与 --xia-*-rgb 实现主题配色
 */

.page-wrap.scl90-page {
  min-height: 100vh;
  padding-bottom: 120rpx;
  padding: 0 24rpx 120rpx;
}

/* space-y-8 主容器 */
.scl90-main {
  padding-top: 24rpx;
}

/* space-y-4: SectionHeader 块 */
.scl90-header-block {
  margin-bottom: 32rpx;
}

.scl90-header-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.scl90-header-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.scl90-header-icon {
  width: 40rpx;
  height: 40rpx;
}

.test-icon-sky { background: rgba(var(--xia-sky-rgb), 0.2); }

/* SectionHeader - 对应 SectionHeader.tsx */
.section-header {
  margin-bottom: 16rpx;
}

.section-header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--xia-deep);
  line-height: 1.3;
}

.section-header-desc {
  font-size: 28rpx;
  color: var(--xia-deep);
  margin-top: 8rpx;
}

/* 描述 - text-sm text-xia-deep/80 */
.scl90-desc {
  font-size: 28rpx;
  color: var(--xia-deep);
  line-height: 1.5;
}

/* grid gap-6 lg:grid-cols-[2fr,1fr] - 移动端单列堆叠 */
.scl90-grid {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

/* 左列 space-y-6 */
.scl90-left {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

/* ProgressBar - h-2 w-full rounded-full bg-xia-haze/30 */
.scl90-progress-wrap {
  height: 16rpx;
  width: 100%;
  border-radius: 999rpx;
  background: rgba(var(--xia-deep-rgb), 0.12);
  overflow: hidden;
}

/* h-2 rounded-full bg-xia-deep */
.scl90-progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: var(--xia-deep);
  transition: width 0.3s ease;
}

/* QuestionView - rounded-2xl border border-xia-haze bg-white p-4 shadow-sm */
.scl90-question-card {
  border-radius: 32rpx;
  border: 2rpx solid rgba(var(--xia-deep-rgb), 0.12);
  background: #fff;
  padding: 32rpx 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* text-xs text-xia-deep/50 */
.scl90-q-meta {
  font-size: 24rpx;
  color: rgba(var(--xia-deep-rgb), 0.6);
  margin-bottom: 16rpx;
}

/* mt-2 text-base font-medium text-xia-deep */
.scl90-q-text {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--xia-deep);
  line-height: 1.5;
  margin-bottom: 32rpx;
}

/* MBTI 风格横向刻度：非常符合（症状重）左、不符合（无）右 */
.scl90-likert-scale {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.scl90-scale-lbl {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--xia-deep);
  flex-shrink: 0;
  max-width: 80rpx;
}
.scl90-scale-left { text-align: left; }
.scl90-scale-right { text-align: right; }

.scl90-scale-dots {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16rpx;
  gap: 8rpx;
}

.scl90-scale-dot {
  flex-shrink: 0;
  border-radius: 50%;
  border: 4rpx solid rgba(var(--xia-deep-rgb), 0.2);
  background: #fff;
  transition: all 0.2s;
  box-sizing: border-box;
}
.scl90-scale-dot:nth-child(1),
.scl90-scale-dot:nth-child(5) { width: 48rpx; height: 48rpx; min-width: 48rpx; min-height: 48rpx; }
.scl90-scale-dot:nth-child(2),
.scl90-scale-dot:nth-child(4) { width: 40rpx; height: 40rpx; min-width: 40rpx; min-height: 40rpx; }
.scl90-scale-dot:nth-child(3) { width: 28rpx; height: 28rpx; min-width: 28rpx; min-height: 28rpx; }

.scl90-scale-dot.selected {
  background: var(--xia-deep);
  border-color: var(--xia-deep);
}

.scl90-scale-dot:nth-child(1).selected { background: var(--xia-sky); border-color: var(--xia-sky); }
.scl90-scale-dot:nth-child(5).selected { background: var(--xia-deep); border-color: var(--xia-deep); }

.scl90-scale-hint {
  font-size: 22rpx;
  color: var(--xia-deep);
  text-align: center;
  margin-top: 8rpx;
}

/* nav-row: flex items-center justify-between */
.scl90-nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 上一题 - 描边样式 */
.scl90-btn-prev, .scl90-btn-next { margin: 0; line-height: 1.4; }
.scl90-btn-prev::after, .scl90-btn-next::after { border: none; }
.scl90-btn-prev {
  border: 2rpx solid rgba(var(--xia-deep-rgb), 0.2);
  border-radius: 999rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: var(--xia-deep);
  background: transparent;
}
.scl90-btn-prev[disabled] { opacity: 0.5; }

/* 已完成 x/y - text-sm text-xia-teal/80 */
.scl90-progress-text {
  font-size: 28rpx;
  color: var(--xia-deep);
}

/* 下一题 - rounded-full border border-xia-deep bg-xia-deep text-white */
.scl90-btn-next {
  border: 2rpx solid var(--xia-deep);
  border-radius: 999rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #fff;
  background: var(--xia-deep);
  margin: 0;
  line-height: 1.4;
}

.scl90-btn-next[disabled] {
  opacity: 0.5;
}

/* 查看分析结果 - canSubmit: bg-xia-deep text-white; else: bg-xia-haze/30 text-xia-haze */
.scl90-btn-submit {
  width: 100%;
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: var(--xia-deep);
  border: none;
  margin: 0;
}

.scl90-btn-submit-disabled {
  background: rgba(var(--xia-deep-rgb), 0.12);
  color: rgba(var(--xia-deep-rgb), 0.4);
}

/* 右列 aside - 作答提示 */
.scl90-right {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* aside: rounded-2xl border border-xia-haze bg-white p-6 shadow-sm */
.scl90-tips-card {
  border-radius: 32rpx;
  border: 2rpx solid rgba(var(--xia-deep-rgb), 0.12);
  background: #fff;
  padding: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* text-sm font-semibold text-xia-deep */
.scl90-tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--xia-deep);
  margin-bottom: 16rpx;
}

/* space-y-2 text-sm text-xia-deep/80 */
.scl90-tips-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.scl90-tips-item {
  font-size: 28rpx;
  color: var(--xia-deep);
  line-height: 1.6;
}

/* QuestionOverview - rounded-2xl border border-xia-haze bg-white p-4 shadow-sm */
.scl90-overview-card {
  border-radius: 32rpx;
  border: 2rpx solid rgba(var(--xia-deep-rgb), 0.12);
  background: #fff;
  padding: 32rpx 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* flex items-center justify-between text-sm font-semibold text-xia-deep */
.scl90-overview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.scl90-overview-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--xia-deep);
}

/* text-xs font-medium text-xia-deep/60 */
.scl90-overview-count {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--xia-deep);
}

/* mt-2 flex flex-wrap gap-2 text-[11px] text-xia-deep/60 */
.scl90-overview-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
  font-size: 22rpx;
  color: var(--xia-deep);
}

.scl90-legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.scl90-legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

/* 已作答: bg-xia-sky */
.scl90-dot-answered {
  background: var(--xia-sky);
}

/* 未作答 */
.scl90-dot-unanswered {
  background: rgba(var(--xia-deep-rgb), 0.2);
}

/* 当前题: bg-xia-deep */
.scl90-dot-current {
  background: var(--xia-deep);
}

/* mt-4 grid grid-cols-6 gap-2 - 题目按钮网格 */
.scl90-overview-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx;
}

.scl90-overview-btn {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  border: 2rpx solid;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.2s;
}

/* 当前题: border-xia-deep bg-xia-deep text-white */
.scl90-overview-current {
  border-color: var(--xia-deep);
  background: var(--xia-deep);
  color: #fff;
}

/* 已作答: border-xia-sky/50 bg-xia-sky/20 text-xia-sky */
.scl90-overview-answered {
  border-color: rgba(var(--xia-sky-rgb), 0.5);
  background: rgba(var(--xia-sky-rgb), 0.2);
  color: var(--xia-sky);
}

/* 未作答 */
.scl90-overview-unanswered {
  border-color: rgba(var(--xia-deep-rgb), 0.15);
  background: #fff;
  color: rgba(var(--xia-deep-rgb), 0.5);
}
