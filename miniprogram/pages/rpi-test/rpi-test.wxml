<!-- RPI 答题页 - 移植自 RPITest.tsx，双视角 -->
<view class="page-wrap rpi-page" style="{{themeStyle}}">
  <view class="rpi-main" wx:if="{{test}}">
    <view class="rpi-header-block">
      <view class="section-header">
        <view class="section-header-title">{{test.title}}</view>
        <view class="section-header-desc" wx:if="{{test.subtitle}}">{{test.subtitle}}</view>
      </view>
      <view class="rpi-desc">{{test.description}}</view>
    </view>

    <!-- 视角切换 -->
    <view class="rpi-perspective-row">
      <view
        class="rpi-perspective-btn {{perspective === 'self' ? 'rpi-perspective-active' : ''}}"
        data-perspective="self"
        bindtap="onSwitchPerspective"
      >自我视角</view>
      <view
        class="rpi-perspective-btn {{perspective === 'partner' ? 'rpi-perspective-active' : ''}}"
        data-perspective="partner"
        bindtap="onSwitchPerspective"
      >伴侣视角</view>
    </view>
    <view class="rpi-progress-hint">自我 {{selfAnswered}}/20 · 伴侣 {{partnerAnswered}}/20</view>

    <view class="rpi-grid">
      <view class="rpi-left">
        <view class="rpi-progress-wrap">
          <view class="rpi-progress-bar" style="width: {{progress}}%"></view>
        </view>

        <view class="rpi-question-card" wx:if="{{currentQ}}">
          <view class="rpi-q-meta">题目 {{current + 1}}/{{total}}</view>
          <view class="rpi-q-text">{{currentQ.text}}</view>
          <view class="rpi-options-grid">
            <view
              wx:for="{{test.options}}"
              wx:key="value"
              class="rpi-opt {{answers[currentQ.id] === item.value ? 'rpi-opt-selected' : ''}}"
              data-value="{{item.value}}"
              bindtap="onSelect"
            >{{item.label}}</view>
          </view>
        </view>

        <view class="rpi-nav-row">
          <button class="rpi-btn-prev" disabled="{{current === 0}}" bindtap="goPrev">上一题</button>
          <view class="rpi-progress-text">已完成 {{answeredCount}}/{{total}}</view>
          <button class="rpi-btn-next" disabled="{{current >= total - 1}}" bindtap="goNext">下一题</button>
        </view>

        <button
          class="rpi-btn-submit {{canSubmit ? '' : 'rpi-btn-submit-disabled'}}"
          disabled="{{!canSubmit}}"
          bindtap="onSubmit"
        >查看分析结果</button>
      </view>

      <view class="rpi-right">
        <view class="rpi-tips-card">
          <view class="rpi-tips-title">作答提示</view>
          <view class="rpi-tips-list">
            <view wx:for="{{test.instructions}}" wx:key="*this" class="rpi-tips-item">• {{item}}</view>
          </view>
        </view>

        <view class="rpi-overview-card">
          <view class="rpi-overview-header">
            <text class="rpi-overview-title">{{perspective === 'self' ? '自我' : '伴侣'}}视角题目总览</text>
            <text class="rpi-overview-count">已答 {{answeredCount}}/{{total}}</text>
          </view>
          <view class="rpi-overview-legend">
            <view class="rpi-legend-item"><view class="rpi-legend-dot rpi-dot-answered"></view><text>已作答</text></view>
            <view class="rpi-legend-item"><view class="rpi-legend-dot rpi-dot-unanswered"></view><text>未作答</text></view>
            <view class="rpi-legend-item"><view class="rpi-legend-dot rpi-dot-current"></view><text>当前题</text></view>
          </view>
          <view class="rpi-overview-grid">
            <view
              wx:for="{{questions}}"
              wx:for-item="q"
              wx:key="id"
              class="rpi-overview-btn {{current === index ? 'rpi-overview-current' : (answers[q.id] !== undefined ? 'rpi-overview-answered' : 'rpi-overview-unanswered')}}"
              data-index="{{index}}"
              bindtap="onOverviewTap"
            >{{index + 1}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <theme-switcher bindthemechange="onThemeChange"></theme-switcher>
</view>
