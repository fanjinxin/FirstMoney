/**
 * RPI 答题页样式 - 与 scl90-test 结构一致，使用主题变量保证可读性
 */
.page-wrap.rpi-page {
  min-height: 100vh;
  padding-bottom: 120rpx;
  padding: 0 24rpx 120rpx;
}

.rpi-main { padding-top: 24rpx; }
.rpi-header-block { margin-bottom: 32rpx; }

.section-header { margin-bottom: 16rpx; }
.section-header-title { font-size: 40rpx; font-weight: 600; color: var(--xia-deep); line-height: 1.3; }
.section-header-desc { font-size: 28rpx; color: var(--xia-deep); margin-top: 8rpx; }

.rpi-desc { font-size: 28rpx; color: var(--xia-deep); line-height: 1.5; }

/* 视角切换 */
.rpi-perspective-row { display: flex; gap: 24rpx; margin-bottom: 16rpx; flex-wrap: wrap; }
.rpi-perspective-btn {
  border-radius: 999rpx; padding: 16rpx 36rpx; font-size: 28rpx; font-weight: 500;
  border: 2rpx solid rgba(var(--xia-deep-rgb), 0.15);
  background: rgba(var(--xia-deep-rgb), 0.04);
  color: rgba(var(--xia-deep-rgb), 0.6);
}
.rpi-perspective-active {
  background: var(--xia-deep); color: #fff; border-color: var(--xia-deep);
}
.rpi-progress-hint { font-size: 24rpx; color: rgba(var(--xia-deep-rgb), 0.7); margin-bottom: 32rpx; }

.rpi-grid { display: flex; flex-direction: column; gap: 48rpx; }
.rpi-left { display: flex; flex-direction: column; gap: 48rpx; }

/* 进度条 */
.rpi-progress-wrap {
  height: 16rpx; width: 100%; border-radius: 999rpx;
  background: rgba(var(--xia-deep-rgb), 0.12); overflow: hidden;
}
.rpi-progress-bar { height: 100%; border-radius: 999rpx; background: var(--xia-deep); transition: width 0.3s ease; }

/* 题目卡片 */
.rpi-question-card {
  border-radius: 32rpx; border: 2rpx solid rgba(var(--xia-deep-rgb), 0.12);
  background: #fff; padding: 32rpx 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(var(--xia-deep-rgb), 0.04);
}
.rpi-q-meta { font-size: 24rpx; color: rgba(var(--xia-deep-rgb), 0.6); margin-bottom: 16rpx; }
.rpi-q-text { font-size: 32rpx; font-weight: 500; color: var(--xia-deep); line-height: 1.5; margin-bottom: 32rpx; }

/* MBTI 风格横向刻度：非常符合左、不符合右 */
.rpi-likert-scale {
  display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx;
}
.rpi-scale-lbl {
  font-size: 22rpx; font-weight: 600; color: var(--xia-deep); flex-shrink: 0; max-width: 80rpx;
}
.rpi-scale-left { text-align: left; }
.rpi-scale-right { text-align: right; }
.rpi-scale-dots {
  flex: 1; display: flex; align-items: center; justify-content: space-between;
  padding: 0 16rpx; gap: 8rpx;
}
.rpi-scale-dot {
  flex-shrink: 0; border-radius: 50%;
  border: 4rpx solid rgba(var(--xia-deep-rgb), 0.2); background: #fff; transition: all 0.2s;
  box-sizing: border-box;
}
.rpi-scale-dot:nth-child(1),
.rpi-scale-dot:nth-child(5) { width: 48rpx; height: 48rpx; min-width: 48rpx; min-height: 48rpx; }
.rpi-scale-dot:nth-child(2),
.rpi-scale-dot:nth-child(4) { width: 40rpx; height: 40rpx; min-width: 40rpx; min-height: 40rpx; }
.rpi-scale-dot:nth-child(3) { width: 28rpx; height: 28rpx; min-width: 28rpx; min-height: 28rpx; }
.rpi-scale-dot.selected {
  background: var(--xia-deep); border-color: var(--xia-deep);
}
.rpi-scale-dot:nth-child(1).selected { background: var(--xia-sky); border-color: var(--xia-sky); }
.rpi-scale-dot:nth-child(5).selected { background: var(--xia-deep); border-color: var(--xia-deep); }
.rpi-scale-hint { font-size: 22rpx; color: var(--xia-deep); text-align: center; margin-top: 8rpx; }

/* 导航 */
.rpi-nav-row { display: flex; align-items: center; justify-content: space-between; }
.rpi-btn-prev, .rpi-btn-next { margin: 0; line-height: 1.4; }
.rpi-btn-prev::after, .rpi-btn-next::after { border: none; }
.rpi-btn-prev {
  border: 2rpx solid rgba(var(--xia-deep-rgb), 0.2); border-radius: 999rpx;
  padding: 16rpx 32rpx; font-size: 28rpx; color: var(--xia-deep);
  background: transparent;
}
.rpi-btn-prev[disabled] { opacity: 0.5; }
.rpi-progress-text { font-size: 28rpx; color: var(--xia-deep); }
.rpi-btn-next {
  border: 2rpx solid var(--xia-deep); border-radius: 999rpx;
  padding: 16rpx 32rpx; font-size: 28rpx; color: #fff; background: var(--xia-deep);
}
.rpi-btn-next[disabled] { opacity: 0.5; }

/* 提交按钮 */
.rpi-btn-submit {
  width: 100%; border-radius: 32rpx; padding: 28rpx 32rpx; font-size: 28rpx;
  font-weight: 600; color: #fff; background: var(--xia-deep); border: none; margin: 0;
}
.rpi-btn-submit-disabled {
  background: rgba(var(--xia-deep-rgb), 0.12); color: rgba(var(--xia-deep-rgb), 0.4);
}

/* 右列 */
.rpi-right { display: flex; flex-direction: column; gap: 32rpx; }

.rpi-tips-card {
  border-radius: 32rpx; border: 2rpx solid rgba(var(--xia-deep-rgb), 0.12);
  background: #fff; padding: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(var(--xia-deep-rgb), 0.04);
}
.rpi-tips-title { font-size: 28rpx; font-weight: 600; color: var(--xia-deep); margin-bottom: 16rpx; }
.rpi-tips-list { display: flex; flex-direction: column; gap: 8rpx; }
.rpi-tips-item { font-size: 28rpx; color: var(--xia-deep); line-height: 1.6; }

.rpi-overview-card {
  border-radius: 32rpx; border: 2rpx solid rgba(var(--xia-deep-rgb), 0.12);
  background: #fff; padding: 32rpx 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(var(--xia-deep-rgb), 0.04);
}
.rpi-overview-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.rpi-overview-title { font-size: 28rpx; font-weight: 600; color: var(--xia-deep); }
.rpi-overview-count { font-size: 24rpx; font-weight: 500; color: rgba(var(--xia-deep-rgb), 0.6); }
.rpi-overview-legend { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 24rpx; font-size: 22rpx; color: var(--xia-deep); }
.rpi-legend-item { display: flex; align-items: center; gap: 8rpx; }
.rpi-legend-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
.rpi-dot-answered { background: var(--xia-teal); }
.rpi-dot-unanswered { background: rgba(var(--xia-deep-rgb), 0.2); }
.rpi-dot-current { background: var(--xia-deep); }

.rpi-overview-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16rpx; }
.rpi-overview-btn {
  height: 64rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 16rpx; border: 2rpx solid; font-size: 24rpx; font-weight: 600;
}
.rpi-overview-current { border-color: var(--xia-deep); background: var(--xia-deep); color: #fff; }
.rpi-overview-answered { border-color: rgba(var(--xia-teal-rgb), 0.5); background: rgba(var(--xia-teal-rgb), 0.15); color: var(--xia-teal); }
.rpi-overview-unanswered { border-color: rgba(var(--xia-deep-rgb), 0.15); background: #fff; color: rgba(var(--xia-deep-rgb), 0.5); }
