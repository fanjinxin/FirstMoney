<view class="page-wrap" style="{{themeStyle}}">
  <nav-header currentPath="{{currentPath}}" sticky="{{true}}" indexMode="{{true}}" bindtabchange="onNavTabChange"></nav-header>
  <!-- Hero 介绍区：简约但有设计感 -->
  <view class="hero-intro" id="section-hero">
    <view class="hero-divider hero-divider-top">
      <view class="hero-divider-line"></view>
      <view class="hero-divider-icon"></view>
      <view class="hero-divider-line"></view>
    </view>
    <view class="hero-title">更酷的测评体验，<text class="hero-title-accent">快速获得</text>多维度洞察</view>
    <view class="hero-desc">更直观的流程、更清晰的反馈、更有节奏的体验感，帮助你专注于真实感受。测试结果将以图表与建议结合的方式呈现。</view>
    <view class="hero-feature">
      <view class="hero-feature-main">
        <view class="hero-feature-icon hero-highlight-icon-chart"></view>
        <text class="hero-feature-text">自动生成个性化建议 · 多维图表 + 可执行建议</text>
      </view>
      <view class="hero-feature-tags">
        <view class="hero-feature-tag">即时解析</view>
        <view class="hero-feature-tag">多维度雷达</view>
        <view class="hero-feature-tag">隐私友好</view>
      </view>
    </view>
    <view class="hero-divider hero-divider-bottom">
      <view class="hero-divider-line"></view>
      <view class="hero-divider-icon"></view>
      <view class="hero-divider-line"></view>
    </view>
  </view>

  <!-- 测评卡片网格：md:grid-cols-3 -->
  <view class="test-grid">
    <view 
      wx:for="{{tests}}" 
      wx:key="id"
      id="section-{{item.id}}"
      class="test-card test-card-{{item.bgType}}"
      data-id="{{item.id}}"
      bindtap="onTestTap"
    >
      <view class="test-card-overlay"></view>
      <view class="test-card-content">
        <view class="test-card-header">
          <view class="test-icon-wrap test-icon-{{item.iconBg}}">
            <image wx:if="{{item.iconType === 'huolande'}}" class="test-icon-img" src="/assets/huolande-icon.png" mode="aspectFit"></image>
            <image wx:else class="test-icon-img" src="/assets/icons/{{item.iconType}}.svg" mode="aspectFit"></image>
          </view>
          <view class="test-subtitle-wrap">
            <view wx:if="{{item.hot}}" class="test-hot-tag"><image class="test-hot-flame" src="/assets/icons/flame-hot.svg" mode="aspectFit" /><text class="test-hot-text">hot</text></view>
            <view class="test-subtitle-tag">{{item.subtitle}}</view>
          </view>
        </view>
        <view class="test-card-title">{{item.title}}</view>
        <view class="test-card-desc">{{item.description}}</view>
        <view class="test-meta-row">
          <view class="test-meta-tag" wx:if="{{item.metaText}}">{{item.metaText}}</view>
          <text wx:if="{{item.usageText}}" class="test-usage-text">{{item.usageText}}</text>
        </view>
      </view>
      <view class="test-card-footer">
        <view class="test-action-link" catchtap="onTestTap" data-id="{{item.id}}">开始测评 →</view>
        <view 
          wx:if="{{showBackdoorBtn}}"
          class="test-jump-btn"
          data-id="{{item.id}}"
          catchtap="onTestJump"
        >测试：直接查看结果</view>
      </view>
    </view>
  </view>

  <theme-switcher bindthemechange="onThemeChange"></theme-switcher>

  <!-- Footer：严格还原 Layout footer -->
  <view class="footer" bindtap="onDisclaimerTap">
    <view class="footer-title">免责声明</view>
    <view class="footer-text">本网站所有测评均为自评工具，仅供自我探索与娱乐参考，不构成任何专业心理评估、临床诊断或医疗建议。测评题目与结果解释仅供学习交流，如有持续困扰请寻求专业心理咨询或医疗机构帮助。数据在本地处理，不上传服务器。</view>
  </view>
</view>
