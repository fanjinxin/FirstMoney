/* 首页 - 严格按照 Web 版 Home.tsx + Layout 移植 */

.page-wrap {
  padding: 32rpx 24rpx 48rpx;
}

/* ========== Hero 区 ========== */
.hero-section {
  position: relative;
  overflow: hidden;
  border-radius: 48rpx;
  border: 2rpx solid var(--xia-haze);
  background: linear-gradient(135deg, #fff 0%, #fff 50%, rgba(248, 244, 225, 0.2) 100%);
  padding: 48rpx 40rpx 56rpx;
  margin-bottom: 64rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.hero-orb {
  position: absolute;
  pointer-events: none;
  border-radius: 50%;
  animation: glow 6s ease-in-out infinite;
}

.hero-orb-right {
  right: -96rpx;
  top: 48rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(127, 191, 225, 0.2);
  filter: blur(80rpx);
}

.hero-orb-left {
  left: -128rpx;
  top: -160rpx;
  width: 384rpx;
  height: 384rpx;
  background: rgba(152, 230, 226, 0.2);
  filter: blur(80rpx);
}

@keyframes glow {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.08); }
}

.hero-grid {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

@media (min-width: 700px) {
  .hero-grid {
    flex-direction: row;
    gap: 80rpx;
    align-items: stretch;
  }
  .hero-col-left {
    flex: 1.1;
  }
  .hero-col-right {
    flex: 0.9;
  }
}

.hero-col-left {
  flex: 1;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: rgba(15, 76, 92, 0.05);
  border-radius: 999rpx;
  margin-bottom: 40rpx;
}

.badge-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--xia-aqua);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.badge-text {
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(15, 76, 92, 0.6);
  letter-spacing: 0.1em;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--xia-deep);
  line-height: 1.25;
  margin-bottom: 24rpx;
}

.hero-desc {
  font-size: 28rpx;
  color: rgba(15, 76, 92, 0.8);
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.hero-tag {
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(15, 76, 92, 0.7);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.hero-col-right {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

@media (min-width: 500px) and (max-width: 900px) {
  .hero-col-right {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24rpx;
  }
}

.hero-card {
  border-radius: 32rpx;
  border: 2rpx solid rgba(207, 239, 240, 0.8);
  background: rgba(255, 255, 255, 0.8);
  padding: 32rpx 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.hero-card-label {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(15, 76, 92, 0.4);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

.hero-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--xia-deep);
  margin-bottom: 12rpx;
}

.hero-card-desc {
  font-size: 28rpx;
  color: rgba(15, 76, 92, 0.8);
  line-height: 1.5;
}

.hero-card-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.hero-card-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: rgba(15, 76, 92, 0.05);
  border-radius: 24rpx;
}

.hero-card-text {
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(15, 76, 92, 0.7);
}

.hero-progress-wrap {
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(207, 239, 240, 0.5);
}

.hero-progress-bar {
  width: 75%;
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(to right, var(--xia-sky), var(--xia-deep));
  animation: fillBar 0.8s ease-out;
}

@keyframes fillBar {
  from { width: 0; }
}

/* ========== 测评卡片网格 ========== */
.test-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 32rpx 48rpx;
}

@media (min-width: 600px) {
  .test-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 900px) {
  .test-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.test-card {
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 32rpx;
  border: 2rpx solid var(--xia-haze);
  padding: 32rpx 40rpx;
  min-height: 320rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.test-card:active {
  transform: translateY(-4rpx);
  border-color: rgba(44, 111, 122, 0.3);
  box-shadow: 0 8rpx 24rpx rgba(15, 76, 92, 0.08);
}

.test-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.6) 50%, rgba(248, 244, 225, 0.3) 100%);
  opacity: 0;
  pointer-events: none;
}

.test-card:active .test-card-overlay {
  opacity: 1;
}

/* 背景渐变 - 对应 Web 版 backgroundClass */
.test-card-sky { background: linear-gradient(135deg, rgba(127,191,225,0.1) 0%, #fff 50%, rgba(207,239,240,0.2) 100%); }
.test-card-mint { background: linear-gradient(135deg, rgba(152,230,226,0.1) 0%, #fff 50%, rgba(248,244,225,0.3) 100%); }
.test-card-cream-haze { background: linear-gradient(135deg, rgba(248,244,225,0.3) 0%, #fff 50%, rgba(207,239,240,0.2) 100%); }
.test-card-cream-sky { background: linear-gradient(135deg, rgba(248,244,225,0.2) 0%, #fff 50%, rgba(127,191,225,0.1) 100%); }
.test-card-aqua { background: linear-gradient(135deg, rgba(104,212,219,0.1) 0%, #fff 50%, rgba(248,244,225,0.2) 100%); }

.test-card-content {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.test-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.test-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.test-icon-emoji {
  font-size: 44rpx;
}

.test-icon-img {
  width: 100%;
  height: 100%;
}

.test-icon-sky { background: rgba(127, 191, 225, 0.2); }
.test-icon-mint { background: rgba(152, 230, 226, 0.2); }
.test-icon-aqua { background: rgba(104, 212, 219, 0.2); }
.test-icon-cream { background: rgba(248, 244, 225, 0.9); }
.test-icon-deep { background: rgba(15, 76, 92, 0.1); }

.test-subtitle-tag {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(15, 76, 92, 0.6);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  background: rgba(15, 76, 92, 0.05);
}

.test-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--xia-deep);
  margin-bottom: 16rpx;
  line-height: 1.3;
}

.test-card-desc {
  font-size: 26rpx;
  color: rgba(15, 76, 92, 0.8);
  line-height: 1.5;
  flex: 1;
}

.test-meta-tag {
  display: inline-flex;
  margin-top: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(15, 76, 92, 0.7);
  background: rgba(15, 76, 92, 0.05);
  align-self: flex-start;
}

.test-card-footer {
  position: relative;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 24rpx;
  margin-top: 40rpx;
  padding-top: 32rpx;
}

.test-action-link {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--xia-deep);
  text-decoration: underline;
}

.test-jump-btn {
  padding: 20rpx 28rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(152, 230, 226, 0.5);
  background: rgba(152, 230, 226, 0.1);
  font-size: 24rpx;
  font-weight: 500;
  color: var(--xia-teal);
}

.test-jump-btn:active {
  background: rgba(152, 230, 226, 0.2);
}

/* ========== Footer ========== */
.footer {
  margin-top: 64rpx;
  padding: 48rpx 0 32rpx;
  border-top: 2rpx solid var(--xia-haze);
  background: rgba(255, 255, 255, 0.6);
}

.footer-title {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(15, 76, 92, 0.7);
  margin-bottom: 16rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(15, 76, 92, 0.6);
  line-height: 1.6;
}
