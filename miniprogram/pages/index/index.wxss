/* 首页 - 严格按照 Web 版 Home.tsx + Layout 移植 */

.page-wrap {
  padding: 32rpx 24rpx 48rpx;
}

/* ========== Hero 介绍区：简约但有设计感 ========== */
.hero-intro {
  position: relative;
  padding: 0 0 48rpx;
  margin-bottom: 48rpx;
}

/* 标题：强调短语用主题色 */
.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--xia-deep);
  line-height: 1.35;
  letter-spacing: 0.02em;
  margin-bottom: 24rpx;
}

.hero-title-accent {
  color: var(--xia-teal);
  font-weight: 700;
  position: relative;
}

.hero-desc {
  font-size: 28rpx;
  color: rgba(var(--xia-deep-rgb), 0.72);
  line-height: 1.7;
  letter-spacing: 0.02em;
  margin-bottom: 24rpx;
}

/* 标题上方分隔符：渐变线 + 菱形 */
.hero-divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
}

.hero-divider-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(var(--xia-teal-rgb), 0.25) 50%, transparent 100%);
}

.hero-divider-icon {
  width: 16rpx;
  height: 16rpx;
  flex-shrink: 0;
  transform: rotate(45deg);
  background: linear-gradient(135deg, var(--xia-teal) 0%, rgba(var(--xia-teal-rgb), 0.5) 100%);
  border-radius: 2rpx;
}

.hero-divider-top {
  margin-top: 24rpx;
  margin-bottom: 20rpx;
}

.hero-divider-bottom {
  margin-top: 8rpx;
}

/* 功能块：亮点文案 + 标签合并，统一风格，无选中态 */
.hero-feature {
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(var(--xia-teal-rgb), 0.06);
  border: 1rpx solid rgba(var(--xia-teal-rgb), 0.12);
  margin-bottom: 32rpx;
}

.hero-feature-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.hero-feature-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.hero-highlight-icon-chart {
  background-color: var(--xia-teal);
  -webkit-mask: url('data:image/svg+xml;base64,') center/contain no-repeat;
  mask: url('data:image/svg+xml;base64,') center/contain no-repeat;
}

.hero-feature-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--xia-teal);
  line-height: 1.4;
}

.hero-feature-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.hero-feature-tag {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(var(--xia-deep-rgb), 0.75);
  border-radius: 999rpx;
  border: 1.5rpx solid rgba(var(--xia-teal-rgb), 0.3);
  background: rgba(255, 255, 255, 0.6);
}

/* ========== 测评卡片网格 ========== */
.test-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 32rpx 48rpx;
}

@media (min-width: 600px) {
  .test-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 900px) {
  .test-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.test-card {
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 32rpx;
  border: 2rpx solid var(--xia-haze);
  padding: 32rpx 40rpx;
  min-height: 320rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.test-card:active {
  transform: translateY(-4rpx);
  border-color: rgba(var(--xia-teal-rgb), 0.3);
  box-shadow: 0 8rpx 24rpx rgba(var(--xia-deep-rgb), 0.08);
}

.test-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.6) 50%, rgba(var(--xia-cream-rgb), 0.3) 100%);
  opacity: 0;
  pointer-events: none;
}

.test-card:active .test-card-overlay {
  opacity: 1;
}

/* 背景渐变 - 使用主题变量 */
.test-card-sky { background: linear-gradient(135deg, rgba(var(--xia-sky-rgb), 0.1) 0%, #fff 50%, rgba(var(--xia-haze-rgb), 0.2) 100%); }
.test-card-mint { background: linear-gradient(135deg, rgba(var(--xia-mint-rgb), 0.1) 0%, #fff 50%, rgba(var(--xia-cream-rgb), 0.3) 100%); }
.test-card-cream-haze { background: linear-gradient(135deg, rgba(var(--xia-cream-rgb), 0.3) 0%, #fff 50%, rgba(var(--xia-haze-rgb), 0.2) 100%); }
.test-card-cream-sky { background: linear-gradient(135deg, rgba(var(--xia-cream-rgb), 0.2) 0%, #fff 50%, rgba(var(--xia-sky-rgb), 0.1) 100%); }
.test-card-aqua { background: linear-gradient(135deg, rgba(var(--xia-aqua-rgb), 0.1) 0%, #fff 50%, rgba(var(--xia-cream-rgb), 0.2) 100%); }

.test-card-content {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.test-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.test-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.test-icon-emoji {
  font-size: 44rpx;
}

.test-icon-img {
  width: 100%;
  height: 100%;
}

.test-icon-sky { background: rgba(var(--xia-sky-rgb), 0.2); }
.test-icon-mint { background: rgba(var(--xia-mint-rgb), 0.2); }
.test-icon-aqua { background: rgba(var(--xia-aqua-rgb), 0.2); }
.test-icon-cream { background: rgba(var(--xia-cream-rgb), 0.9); }
.test-icon-deep { background: rgba(var(--xia-deep-rgb), 0.1); }

.test-subtitle-tag {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(var(--xia-deep-rgb), 0.6);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  background: rgba(var(--xia-deep-rgb), 0.05);
}

.test-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--xia-deep);
  margin-bottom: 16rpx;
  line-height: 1.3;
}

.test-card-desc {
  font-size: 26rpx;
  color: rgba(var(--xia-deep-rgb), 0.8);
  line-height: 1.5;
  flex: 1;
}

.test-meta-tag {
  display: inline-flex;
  margin-top: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(var(--xia-deep-rgb), 0.7);
  background: rgba(var(--xia-deep-rgb), 0.05);
  align-self: flex-start;
}

.test-card-footer {
  position: relative;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 24rpx;
  margin-top: 40rpx;
  padding-top: 32rpx;
}

.test-action-link {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--xia-deep);
  text-decoration: underline;
}

.test-jump-btn {
  padding: 20rpx 28rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(var(--xia-mint-rgb), 0.5);
  background: rgba(var(--xia-mint-rgb), 0.1);
  font-size: 24rpx;
  font-weight: 500;
  color: var(--xia-teal);
}

.test-jump-btn:active {
  background: rgba(var(--xia-mint-rgb), 0.2);
}

/* ========== Footer ========== */
.footer {
  margin-top: 64rpx;
  padding: 48rpx 0 32rpx;
  border-top: 2rpx solid var(--xia-haze);
  background: rgba(255, 255, 255, 0.6);
}

.footer-title {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(var(--xia-deep-rgb), 0.7);
  margin-bottom: 16rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(var(--xia-deep-rgb), 0.6);
  line-height: 1.6;
}
